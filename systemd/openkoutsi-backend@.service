[Unit]
Description=openkoutsi backend
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/projects/openkoutsi-backend
EnvironmentFile=/home/%i/projects/openkoutsi-backend/.env
ExecStart=/home/%i/.local/bin/uv run uvicorn backend.main:app --host 0.0.0.0 --port 8083
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
